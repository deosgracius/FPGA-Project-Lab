## Clock Signal (100 MHz)
set_property -dict { PACKAGE_PIN W5  IOSTANDARD LVCMOS33 } [get_ports clk]

#set_property -dict { PACKAGE_PIN V17  IOSTANDARD LVCMOS33 } [get_ports reset]


